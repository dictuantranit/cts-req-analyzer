@startuml ProbationClassificationBySport_MainFlow
!theme plain
title Probation Classification By Sport - Main Business Flow

start
:Job Triggered (HTTP POST);
note right
    Endpoint: /api/classificationBySportJobs/ScanProbationClassificationBySport
    No parameters required
end note

:ProbationClassificationBySportJobService.Execute();

repeat :Do-While Loop
    :JobRun();
    
    :Start();
    note right
        Initialize ProbationBySportModel
        probationData = new ProbationBySportModel()
    end note
    
    :GetProbationScanClassificationBySport();
    note right
        Call CTS_DC_CustClassification_BySport_ProbationScan_Get [SP]
        Database: CTS_DataCenter (MySQL)
        Parameters:
        - @op_LastCustID (OUTPUT)
        Logic:
        - Get BatchSize from SystemParameter (ParameterID = 168)
        - Get LastCustID from SystemParameter (ParameterID = 169)
        - Find probation customers with:
          * CustID > LastCustID
          * CategoryID = CONST_CATEID_PROBATION
          * LastScannedDate IS NULL OR < CurrentDate
          * CreatedDate < ToLastDay (CurrentDate - 2 days)
          * Active within 30 days
        - Order by CustID ASC
        - Limit by BatchSize
        - Return: CustID, SportGroup
        - Output: LastCustID
        Returns:
        - CustProbations (CustID, SportGroup)
        - LastCustID
    end note
    
    if (Has Customers?) then (yes)
        :PreprocessProbationClassificationBySport();
        note right
            Convert customers to XML
            Call CTS_BySportNormalClassification_Probation_Preprocess [SP]
            Database: bodb_VR2Model (SQL Server)
            Parameters:
            - @CustomersXML (XML)
            Logic:
            - Parse XML customer list
            - Remove disabled accounts
            - Remove inactive customers (no transaction in 30 days)
            - Get Priority from Priority table
            - Call NormalPool_Insert
            - Insert into Normal Pool for classification
        end note
        
        :UpdateCompleteProbationScanBySport();
        note right
            Update SystemParameter:
            - ParameterID = 169 (DailyProbation_BySport_LastCustID)
              Value = LastCustID
            Return: true (continue loop)
        end note
    else (no)
        :UpdateCompleteProbationScanBySport();
        note right
            Update SystemParameter
            Return: false (stop loop)
        end note
    endif
    
repeat while (Has More Customers?) is (yes)
->no;

stop

@enduml

