@startuml DailyNormalClassificationBySport_DatabaseFlow
!theme plain
title Daily Normal Classification By Sport - Database Flow Diagram

start
:Job Triggered;

:GetCustClassificationForDailyScanning;
note right
    Database: CTS_DataCenter (MySQL)
    Stored Procedure: CTS_DC_CustClassification_BySport_DailyScan_GetNormal
    Input:
    - SystemParameter (ParameterID = 114, 115)
    Tables:
    - CustomerCategory
    - CTSCustomerClassification_BySport
    - CTSCustomerAssociationStatus (Archive)
    Output:
    - NormalAccounts (CustID, SportGroup)
    - LastCategoryID, LastCustID
end note

if (Has Customers?) then (yes)
    :PreprocessDailyNormalClassification;
    note right
        Database: bodb_VR2Model (SQL Server)
        Stored Procedure: CTS_BySportNormalClassification_Daily_Preprocess
        Input:
        - CustomersXML
        Tables:
        - custInfo (bodb02)
        - CustomerClassification_BySport_ScannedDailyCust
        - CustomerClassification_BySport_LatestActiveDay
        - CustomerClassification_BySport_Priority
        - Normal Pool (via NormalPool_Insert)
        Logic:
        - Filter disabled accounts
        - Filter already scanned
        - Filter inactive customers
        - Insert into Normal Pool
    end note
    
    :UpdateLastScan;
    note right
        Database: CTS_DataCenter (MySQL)
        Table: SystemParameter
        Updates:
        - ParameterID = 114: LastCategoryID
        - ParameterID = 115: LastCustID
    end note
else (no)
    :UpdateLastScan;
    note right
        Update SystemParameter
        Stop processing
    end note
endif

stop

@enduml

