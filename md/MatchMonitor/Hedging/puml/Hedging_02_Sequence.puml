@startuml Hedging_Sequence
!theme plain
title Hedging Detection - Sequence Diagram

actor "Background Job" as Job
participant "MatchMonitorJobService" as JobService
participant "MatchMonitorRule\nHedgingService" as HedgingService
participant "MatchMonitorRule\nHedgingProcessService" as ProcessService
participant "Association\nDetectionService" as AssocService
participant "MatchMonitorRule\nHedgingDataAccess" as DA
database "CTS_DataCenter\n(MySQL)" as CTS

== Phase 1: Get Matches to Process ==

Job -> JobService: ProcessRuleHedging(isLive, numberInternalOfThread, numberExternalOfThread)
activate JobService

JobService -> HedgingService: GetMatchRuleHedging(isLive)
activate HedgingService

HedgingService -> DA: GetMatchRuleHedging(isLive)
activate DA

DA -> CTS: CALL CTS_DC_MatchMonitor_RuleHedging_Get\n(ip_LiveIndicator, @op_MaxSequenceID)
activate CTS

CTS -> CTS: Read last SequenceID\nfrom SystemParameter

CTS -> CTS: Read rule settings\n(TimeStep, TotalStake)

CTS -> CTS: Load Temp_OldGroup\n(existing groups)

CTS -> CTS: Calculate time window

CTS -> CTS: GROUP BY MatchID, ScoreDiff,\nBettypeID, BetID, Betteam, OldGroupID\nHAVING COUNT(DISTINCT CustID) > 1\nAND SUM(Stake) >= TotalStake

CTS --> DA: Return:\n- MaxSequenceID\n- Match groups\n  (CTSCustIDList, AgentDetect_CTSCustIDList)
deactivate CTS

DA --> HedgingService: MatchMonitorRuleHedgingModel
deactivate DA

HedgingService -> HedgingService: Group by MatchID, ScoreDiff,\nBettypeID, BetID, Betteam

HedgingService --> JobService: MatchStagingRuleHedgingProcessModel
deactivate HedgingService

== Phase 2: Process Each Match (2-Level Parallel) ==

loop For each match (External Parallel)
    JobService -> HedgingService: GetInstanceProcessHedgingService()
    activate HedgingService
    
    HedgingService --> JobService: ProcessService instance
    deactivate HedgingService
    
    JobService -> ProcessService: PrepareProcessWithThread(matchInfo, isLive, numberInternalOfThread)
    activate ProcessService
    
    ProcessService --> JobService: this
    
    JobService -> ProcessService: ProcessRound1()
    
    note over ProcessService
        **Round 1: Association Detection**
        Process match groups in parallel (Internal)
    end note
    
    loop For each match group (Internal Parallel)
        ProcessService -> AssocService: DetectAssociation(param)
        activate AssocService
        note right
            param = {
                CTSCustIds: "...",
                AgentCTSCustIds: "...",
                IsDevice: true,
                IsAI: true,
                IsIP: true
            }
            **Note: 3 criteria only**
        end note
        
        AssocService --> ProcessService: Association result:\n[{CustID: 123, GroupID: 1}, ...]
        deactivate AssocService
        
        ProcessService -> DA: ProcessRuleHedging(\nisLive, matchInfo, sequenceIDList, groupDetection)
        activate DA
        
        DA -> CTS: CALL CTS_DC_MatchMonitor_RuleHedging_Process\n(ip_LiveIndicator, ip_MatchID, ip_ScoreDiff,\nip_BettypeID, ip_BetID, ip_Betteam, ip_SportType,\nip_SequenceIDList, ip_CustGroup)
        activate CTS
        
        CTS -> CTS: Group tickets by TimeStep windows
        
        CTS -> CTS: Calculate IsValidGroup:\nCOUNT(DISTINCT CustID) > 1\nAND SUM(Stake) >= TotalStake
        
        CTS -> CTS: Create Temp_Completed table
        
        loop For each GroupID in Temp_Completed
            CTS -> CTS: Get customers in group
            
            CTS -> CTS: Check latest customer classification\n(IsHedgingReasonMM flag)
            
            alt Customer has IsHedgingReasonMM = 1
                CTS -> CTS: Set IsHedging = TRUE
            else No flag
                CTS -> CTS: CALL CTS_DC_Association_IsAssociatedHedgingCustByCustIDList\n(CustIDList, @IsHedging)
                
                alt Associated hedging detected
                    CTS -> CTS: Set IsHedging = TRUE
                else No association
                    CTS -> CTS: Set IsHedging = FALSE
                end
            end
            
            CTS -> CTS: Update Temp_Completed\nwith IsHedging flag
        end
        
        CTS --> DA: Return:\n- Complete groups (IsHedging = TRUE)\n- Reprocess groups (GroupID = 0)
        deactivate CTS
        
        DA --> ProcessService: MatchProcessRuleHedgingModel
        deactivate DA
    end
    
    ProcessService --> JobService: this
    
    JobService -> ProcessService: ProcessRound2()
    
    note over ProcessService
        **Round 2: Reprocess unassigned tickets**
    end note
    
    alt Has reprocess groups
        loop For each reprocess group (Internal Parallel)
            ProcessService -> AssocService: DetectAssociation(reprocessParam)
            activate AssocService
            
            AssocService --> ProcessService: Association result
            deactivate AssocService
            
            ProcessService -> DA: ProcessRuleHedging(...)
            activate DA
            
            DA -> CTS: CALL Process SP again
            activate CTS
            
            CTS --> DA: Result
            deactivate CTS
            
            DA --> ProcessService: Result
            deactivate DA
        end
    end
    
    ProcessService --> JobService: this
    
    == Phase 3: Complete & Save ==
    
    JobService -> ProcessService: Complete(maxSequenceID)
    
    ProcessService -> DA: CompleteTransRuleHedging(para)
    activate DA
    
    DA -> CTS: CALL CTS_DC_MatchMonitor_RuleHedging_Complete\n(ip_LiveIndicator, ip_MaxSequenceID, ip_MatchID,\nip_ScoreDiff, ip_BettypeID, ip_BetID, ip_Betteam, ip_TransGroup)
    activate CTS
    
    CTS -> CTS: Merge groups by TransIDList
    
    alt Match exists in MatchMonitorDetails
        CTS -> CTS: Merge tickets (UNION)
        CTS -> CTS: UPDATE MatchMonitorDetails
    else Match not exists
        CTS -> CTS: INSERT MatchMonitor
        CTS -> CTS: INSERT MatchMonitorDetails
    end
    
    CTS -> CTS: UPDATE staging table\nSET GroupID
    
    CTS --> DA: Success
    deactivate CTS
    
    DA --> ProcessService: Success
    deactivate DA
    
    ProcessService --> JobService: this
    
    JobService -> ProcessService: WriteLogSentryIfError(...)
    
    ProcessService --> JobService: void
    deactivate ProcessService
end

== Phase 4: Clean Staging ==

JobService -> HedgingService: CleanTransRuleHedging(isLive, maxSequenceID)
activate HedgingService

HedgingService -> DA: CleanTransRuleHedging(isLive, maxSequenceID)
activate DA

DA -> CTS: CALL CTS_DC_MatchMonitor_RuleHedging_StagingClean\n(ip_LiveIndicator, ip_MaxSequenceID)
activate CTS

CTS -> CTS: DELETE FROM staging table\nWHERE SequenceID <= MaxSequenceID

CTS -> CTS: UPDATE SystemParameter\nSET ParameterValue = MaxSequenceID

CTS --> DA: Success
deactivate CTS

DA --> HedgingService: Success
deactivate DA

HedgingService --> JobService: Success
deactivate HedgingService

JobService --> Job: true
deactivate JobService

@enduml

