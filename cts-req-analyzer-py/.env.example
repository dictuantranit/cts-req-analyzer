# API Authentication (for API server mode)
API_KEY=my-secret-key-123

# LLM Provider: openai, gemini, or ollama
LLM_PROVIDER=gemini

# Google Gemini API Key (FREE - get from https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=AIzaSyCuD_IIHigDPonWpPZgqdepHPH0FNP0Ta8

# OpenAI API Key (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Model (only needed if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3.2

# Vector DB Path (optional, defaults to ./data/faiss_db)
VECTOR_DB_PATH=./data/faiss_db

# Documents Path for PlantUML files (optional, defaults to ../md)
DOCS_PATH=../md

# SQL Documents Path for Stored Procedures (optional, leave empty to skip SQL files)
SQL_DOCS_PATH=
