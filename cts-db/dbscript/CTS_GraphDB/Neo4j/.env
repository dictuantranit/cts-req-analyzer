#network
NETWORK_NAME=host
NETWORK_DRIVER=host
NETWORK_EXTERNAL=true

#cluster
CLUSTER_MODE=CORE
CLUSTER_MEMBERS=10.18.200.72:5000,10.18.200.73:5000
CLUSTER_SIZE=2
CLUSTER_TYPE=LIST
CLUSTER_PRE_VOTE=true
CLUSTER_REFUSE_LEADER=false

#neo4j
NEO4J_TAG=neo4j:4.2-enterprise
NEO4J_TZ="America/La_Paz"
HOSTNAME=10.18.200.XX
CONTAINER_NAME=neo4j-core
NEO4J_DATA=/volumes/cts_coreXX_neo4j4.2/data
NEO4J_LOGS=/volumes/cts_coreXX_neo4j4.2/logs
NEO4J_PLUGINS=/volumes/cts_coreXX_neo4j4.2/plugins
NEO4J_IMPORT=/volumes/cts_coreXX_neo4j4.2/import
NEO4J_RUN=/volumes/cts_coreXX_neo4j4.2/run
NEO4J_CONF=/volumes/cts_coreXX_neo4j4.2/conf
NEO4J_METRICS=/volumes/cts_coreXX_neo4j4.2/metrics