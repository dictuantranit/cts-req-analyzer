#Subscriber
NEO4J_streams_sink_topic_cypher_subscriber="call apoc.do.case([event.op = 'c','MERGE (n:Subscriber {SubscriberID: event.after.SubscriberID }) ON CREATE SET n.SubscriberID = event.after.SubscriberID, n.SubscriberName = event.after.SubscriberName',event.op = 'u','MERGE (n:Subscriber {SubscriberID: event.before.SubscriberID }) SET n.SubscriberID = event.after.SubscriberID, n.SubscriberName = event.after.SubscriberName',event.op = 'd','MATCH (n:Subscriber { SubscriberID: event.before.SubscriberID }) SET n:NeedDelete'],'',{event:event}) yield value return value"

#Evidence
NEO4J_streams_sink_topic_cypher_evidence="call apoc.do.case([event.op = 'c','MERGE (n:Evidence { EvidenceID: event.after.EvidenceID }) ON CREATE SET n.EvidenceID = event.after.EvidenceID, n.EvidenceCode = event.after.EvidenceCode, n.EvidenceName = event.after.EvidenceName',event.op = 'u','MATCH (n:Evidence { EvidenceID: event.before.EvidenceID }) SET n.EvidenceID = event.after.EvidenceID, n.EvidenceCode = event.after.EvidenceCode, n.EvidenceName = event.after.EvidenceName',event.op = 'd','MATCH (n:Evidence { EvidenceID: event.before.EvidenceID }) DETACH DELETE n'],'',{event:event}) yield value return value"

#StaticList
NEO4J_streams_sink_topic_cypher_staticlist="call apoc.do.case([event.op = 'c','MERGE (n:StaticList { ListID: event.after.ListID, ItemID: event.after.ItemID }) ON CREATE SET n.ListID = event.after.ListID, n.ItemID = event.after.ItemID, n.ItemNameDisplay = event.after.ItemNameDisplay, n.Status = event.after.Status RETURN n',event.op = 'u','MATCH (n:StaticList { ListID: event.before.ListID, ItemID: event.before.ItemID }) SET n.ListID = event.after.ListID, n.ItemID = event.after.ItemID, n.ItemNameDisplay = event.after.ItemNameDisplay, n.Status = event.after.Status RETURN n',event.op = 'd','MATCH (n:StaticList { ListID: event.before.ListID, ItemID: event.before.ItemID }) SET n:NeedDelete'],'',{event:event}) yield value return value"

#CustomerCategory
NEO4J_streams_sink_topic_cypher_customercategory="call apoc.do.case([event.op = 'c','MERGE (n:CustomerCategory { CategoryID: event.after.CategoryID }) ON CREATE SET n.CategoryID = event.after.CategoryID, n.CategoryName = event.after.CategoryName RETURN n',event.op = 'u','MATCH (n:CustomerCategory { CategoryID: event.before.CategoryID }) SET n.CategoryID = event.after.CategoryID, n.CategoryName = event.after.CategoryName RETURN n',event.op = 'd','MATCH (n:CustomerCategory { CategoryID: event.before.CategoryID }) SET n:NeedDelete'],'',{event:event}) yield value return value"

#CTSCustomer
NEO4J_streams_sink_topic_cypher_ctscustomer="call apoc.do.case([ event.op = 'c','MERGE (n:CTSCustomer { CTSCustID: event.after.CTSCustID }) ON CREATE SET n.CTSCustID = event.after.CTSCustID, n.CustID = event.after.CustID, n.CustSubID = event.after.CustSubID, n.CustStatusID = event.after.CustStatusID, n.RegisterName = event.after.RegisterName, n.Username = event.after.Username, n.Username2 = event.after.Username2 ON MATCH SET n.CTSCustID = event.after.CTSCustID, n.CustID = event.after.CustID, n.CustSubID = event.after.CustSubID, n.CustStatusID = event.after.CustStatusID, n.RegisterName = event.after.RegisterName, n.Username = event.after.Username, n.Username2 = event.after.Username2 WITH n, event MERGE (si:Site {SiteID: event.after.SiteID}) ON CREATE SET si.Site = event.after.Site MERGE (n)-[rs:BELONG_TO_SITE]->(si) ON CREATE SET rs.CreatedDate = datetime() MERGE (st:StaticList {ItemID: event.after.CustStatusID, ListID: 1}) MERGE (n)-[r2:HAS_STATUS]->(st) ON CREATE SET r2.CreatedDate = datetime() WITH n, event WHERE event.after.SubscriberID is not null WITH n, event MERGE (s:Subscriber {SubscriberID: event.after.SubscriberID}) MERGE (n)-[r:BELONG_TO_SUB]->(s) ON CREATE SET r.CreatedDate = datetime()' ,event.op = 'u','MERGE (n:CTSCustomer {CTSCustID: event.before.CTSCustID }) SET n.CTSCustID = event.after.CTSCustID, n.CustID = event.after.CustID, n.CustSubID = event.after.CustSubID, n.CustStatusID = event.after.CustStatusID, n.RegisterName = event.after.RegisterName, n.Username = event.after.Username, n.Username2 = event.after.Username2 WITH n, event OPTIONAL MATCH (n)-[ro:BELONG_TO_SUB]->(s:Subscriber {SubscriberID: event.before.SubscriberID}) DELETE ro WITH n,event OPTIONAL MATCH (n)-[rso:BELONG_TO_SITE]->(si:Site {SiteID: event.before.SiteID}) DELETE rso WITH n,event OPTIONAL MATCH (n)-[r2o:HAS_STATUS]->(st:StaticList {ItemID: event.before.CustStatusID, ListID: 1}) DELETE r2o WITH n,event MERGE (si:Site {SiteID: event.after.SiteID}) MERGE (n)-[rs:BELONG_TO_SITE]->(si) ON CREATE SET rs.CreatedDate = datetime() MERGE (st:StaticList {ItemID: event.after.CustStatusID, ListID: 1}) MERGE (n)-[r2n:HAS_STATUS]->(st) ON CREATE SET r2n.CreatedDate = datetime() WITH n,event WHERE event.after.SubscriberID is not null MERGE (s:Subscriber {SubscriberID: event.after.SubscriberID}) MERGE (n)-[r:BELONG_TO_SUB]->(s) ON CREATE SET r.CreatedDate = datetime()',event.op = 'd','MATCH (n:CTSCustomer {CTSCustID: event.before.CTSCustID }) DETACH DELETE n'],'',{event:event}) yield value return value"

#AssociationByDevice
NEO4J_streams_sink_topic_cypher_associationbydevice="call apoc.do.case([ event.op = 'c','MERGE (c:CTSCustomer {CTSCustID: event.after.CTSCustID}) MERGE (d:Device {DeviceID: event.after.DCSDeviceID}) MERGE (c)-[r:USED_DEVICE {CTSAssDevID: event.after.CTSAssDevID}]->(d) ON CREATE SET r.CreatedTime = event.after.CreatedTime SET c:CookFAD' ,event.op = 'u','MATCH (:CTSCustomer {CTSCustID: event.before.CTSCustID})-[ro:USED_DEVICE]->(:Device {DeviceID: event.before.DCSDeviceID}) DELETE ro WITH event MERGE (c:CTSCustomer {CTSCustID: event.after.CTSCustID}) MERGE (d:Device {DeviceID: event.after.DCSDeviceID}) MERGE (c)-[r:USED_DEVICE {CTSAssDevID: event.after.CTSAssDevID}]->(d) ON CREATE SET r.CreatedTime = event.after.CreatedTime SET c:CookFAD' ,event.op = 'd','MATCH (c:CTSCustomer {CTSCustID: event.before.CTSCustID})-[r:USED_DEVICE]->(d:Device {DeviceID: event.before.DCSDeviceID}) DELETE r'],'',{event:event}) yield value return value"
#CustEvidence
NEO4J_streams_sink_topic_cypher_custevidence="call apoc.do.case([event.op = 'c','MATCH (c:CTSCustomer {CTSCustID: event.after.CTSCustID}),(e:Evidence {EvidenceID: event.after.EvidenceID}) WHERE event.after.Level=0 MERGE (c)-[r:HAS_EVIDENCE]->(e) ON CREATE SET r.CreatedDate = event.after.CreatedDate', event.op = 'u','MATCH (c:CTSCustomer {CTSCustID: event.before.CTSCustID})-[r:HAS_EVIDENCE]->(e:Evidence {EvidenceID: event.before.EvidenceID}) SET r.CreatedDate = event.after.CreatedDate', event.op = 'd','MATCH (c:CTSCustomer {CTSCustID: event.before.CTSCustID})-[r:HAS_EVIDENCE]->(e:Evidence {EvidenceID: event.before.EvidenceID}) DELETE r'],'',{event:event}) yield value return value"

#AssociationRemove
NEO4J_streams_sink_topic_cypher_associationremove="call apoc.do.case([ event.op = 'c','MATCH (c:CTSCustomer {CTSCustID: event.after.FromCTSCustID}) MATCH (c2:CTSCustomer {CTSCustID: event.after.ToCTSCustID}) MERGE (c)-[r:HAS_EXCEPTION]->(c2) ON CREATE SET r.CreatedDate = event.after.CreatedDate RETURN r',event.op = 'u','MATCH (:CTSCustomer {CTSCustID: event.before.FromCTSCustID})-[oldR:HAS_EXCEPTION]->(:CTSCustomer {CTSCustID: event.before.ToCTSCustID}) DELETE oldR WITH event MATCH (c:CTSCustomer {CTSCustID: event.after.FromCTSCustID}) MATCH (c2:CTSCustomer {CTSCustID: event.after.ToCTSCustID}) MERGE (c)-[r:HAS_EXCEPTION]->(c2) ON CREATE SET r.CreatedDate = event.after.CreatedDate RETURN r' ,event.op = 'd','MATCH (:CTSCustomer {CTSCustID: event.before.FromCTSCustID})-[oldR:HAS_EXCEPTION]->(:CTSCustomer {CTSCustID: event.before.ToCTSCustID}) DELETE oldR' ] ,'',{event:event}) yield value return value"

#AssociationByManual
NEO4J_streams_sink_topic_cypher_associationbymanual="call apoc.do.case([ event.op = 'c','MATCH (c:CTSCustomer {CTSCustID: event.after.FromCTSCustID}) MATCH (c2:CTSCustomer {CTSCustID: event.after.ToCTSCustID}) MERGE (c)-[r:ADD_MANUALLY]->(c2) ON CREATE SET r.CreatedDate = event.after.CreatedDate' ,event.op = 'u','MATCH (CTSCustomer {CTSCustID: event.before.FromCTSCustID})-[oldR:ADD_MANUALLY]->(:CTSCustomer {CTSCustID: event.before.ToCTSCustID}) DELETE oldR WITH event MATCH (c:CTSCustomer {CTSCustID: event.after.FromCTSCustID}) MATCH (c2:CTSCustomer {CTSCustID: event.after.ToCTSCustID}) MERGE (c)-[r:ADD_MANUALLY]->(c2) ON CREATE SET r.CreatedDate = event.after.CreatedDate RETURN r' ,event.op = 'd','MATCH (:CTSCustomer {CTSCustID: event.before.FromCTSCustID})-[oldR:ADD_MANUALLY]->(:CTSCustomer {CTSCustID: event.before.ToCTSCustID}) DELETE oldR'],'',{event:event}) yield value return value"

#CTSCustomerClassification
NEO4J_streams_sink_topic_cypher_ctscustomerclassification="call apoc.do.case([event.op = 'c','MERGE (c:CTSCustomer {CustID: event.after.CustID}) MERGE (ct:CustomerCategory {CategoryID: event.after.CategoryID }) MERGE (c)-[r:HAS_CATEGORY]->(ct) ON CREATE SET r.CreatedDate = event.after.CreatedDate', event.op = 'u','MATCH (:CTSCustomer {CustID: event.before.CustID})-[oldR:HAS_CATEGORY]->(:CustomerCategory {CategoryID: event.before.CategoryID}) DELETE oldR WITH event MERGE (c:CTSCustomer {CustID: event.after.CustID}) MERGE (ct:CustomerCategory {CategoryID: event.after.CategoryID }) MERGE (c)-[r:HAS_CATEGORY]->(ct) ON CREATE SET r.CreatedDate = event.after.CreatedDate', event.op = 'd','MATCH (:CTSCustomer {CustID: event.before.CustID})-[oldR:HAS_CATEGORY]->(:CustomerCategory {CategoryID: event.before.CategoryID}) DELETE oldR'],'',{event:event}) yield value return value"