NEO4J_errors_log_enable="true"
NEO4J_errors_log_include_messages="true"
NEO4J_errors_tolerance="all"
NEO4J_kafka_batch_size="16384"
NEO4J_kafka_bootstrap_servers="cts-kafka:9093"
NEO4J_kafka_buffer_memory="134217728"
NEO4J_kafka_group_id="cts_core58_neo4j4.2"
NEO4J_kafka_key_deserializer="org.apache.kafka.common.serialization.ByteArrayDeserializer"
NEO4J_kafka_value_deserializer="org.apache.kafka.common.serialization.ByteArrayDeserializer"
NEO4J_kafka_zookeeper_connect="cts-zookeeper:2181"
NEO4J_streams.sink_errors_deadletterqueue_context_headers_enable="true"
NEO4J_streams_source_enabled="false"
NEO4J_streams_sink_enabled="true"
NEO4J_streams_sink_errors_deadletterqueue_topic_name="cts-error-core58"
NEO4J_streams_sink_errors_tolerance="all"