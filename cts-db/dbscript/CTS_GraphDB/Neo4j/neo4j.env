#neo4j-server
NEO4J_ACCEPT_LICENSE_AGREEMENT="yes"
NEO4J_AUTH=neo4j/admin
NEO4J_dbms_default__database=neo4j
NEO4J_dbms_db_timezone=SYSTEM
NEO4J_dbms_directories_import="/import"

#memory
NEO4J_dbms_memory_heap_initial__size=4G
NEO4J_dbms_memory_heap_max__size=4G
NEO4J_dbms_memory_pagecache_size=6G
NEO4J_dbms_memory_transaction_database__max__size=1G
NEO4J_dbms_memory_transaction_max__size=1G
NEO4J_dbms_memory_transaction_global__max__size=2G

#cypher
NEO4J_cypher_forbid__shortestpath__common__nodes="true"
NEO4J_cypher_forbid__exhaustive__shortestpath="true"

#monitoring
NEO4J_dbms_logs_debug_level=DEBUG
NEO4J_metrics_csv_enabled="false"
NEO4J_metrics_prometheus_enabled="true"
NEO4J_metrics_prometheus_endpoint="0.0.0.0:2004"     

#error handling
NEO4J_errors_tolerance="all"
NEO4J_errors_log_enable="true"
NEO4J_errors_log_include_messages="true"

#logging
NEO4J_dbms_tx__log_rotation_retention__policy=3
NEO4J_dbms_logs_debug_rotation_size="100M"
NEO4J_dbms_logs_debug_rotation_keep__number=10