#network
NETWORK_NAME=neo4j-streaming-network
NETWORK_DRIVER=bridge
NETWORK_EXTERNAL=true

APP_TZ="America/La_Paz"

#zookeeper
ZOOKEEPER_HOST=cts-zookeeper
ZOOKEEPER_PORT=2181
ZOOKEEPER_DATA=./data
ZOOKEEPER_LOGS=./logs

#kafka
KAFKA_HOST=cts-kafka
KAFKA_PORT=9092
KAFKA_PORT_INTERNAL=9093
KAFKA_DATA=./data
KAFKA_LOGS=./logs
KAFKA_BROKER_ID=1
KAFKA_LOG_RETENTION_HOURS=1
KAFKA_RETENTION_MS=3600000
KAFKA_DELETE_RETENTION_MS=3600000

#schema_registry
REGISTRY_HOST=schema_registry
REGISTRY_PORT=8081