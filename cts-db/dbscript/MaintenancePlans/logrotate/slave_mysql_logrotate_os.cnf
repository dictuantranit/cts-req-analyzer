/volumes/cts_slave_mysql80/log/general.log
/volumes/cts_slave_mysql80/log/error.log
/volumes/cts_slave_mysql80/log/slow_query.log
{
        su root docker
        compress
        dateext
        maxsize 300M
        copytruncate
        maxage 365
        dateformat -%Y%m%d%s
        daily
        rotate 30
        notifempty
}
