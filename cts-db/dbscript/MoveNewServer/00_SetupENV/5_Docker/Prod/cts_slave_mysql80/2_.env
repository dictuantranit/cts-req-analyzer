#network
MYSQL_NETWORK=cts_network_prod
EXTERNAL_NETWORK=true
DRIVER_NETWORK=bridge

#mysql container
MYSQL_TAG=8.0.17
MYSQL_HOST=cts_slave_mysql80
MYSQL_PORT=3307
MYSQL_DATA=/volumes/cts_slave_mysql80/data
MYSQL_CONF=/volumes/cts_slave_mysql80/conf.d
MYSQL_LOG=/volumes/cts_slave_mysql80/log
MYSQL_TMP=/volumes/cts_slave_mysql80/tmp
MYSQL_BINLOG=/volumes/cts_slave_mysql80/binlog

#volume
DATA_VOLUME=cts_slave_mysql80_data
EXTERNAL_VOLUME=true
