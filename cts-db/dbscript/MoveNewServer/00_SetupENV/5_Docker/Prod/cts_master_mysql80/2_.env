#network
MYSQL_NETWORK=cts_network_prod
EXTERNAL_NETWORK=true
DRIVER_NETWORK=bridge

#mysql container
MYSQL_TAG=8.0.17
MYSQL_HOST=cts_master_mysql80
MYSQL_PORT=3306
MYSQL_DATA=/dev/mapper/volumes/cts_master_mysql80/data
MYSQL_CONF=/dev/mapper/volumes/cts_master_mysql80/conf.d
MYSQL_LOG=/dev/mapper/volumes/cts_master_mysql80/log
MYSQL_TMP=/dev/mapper/volumes/cts_master_mysql80/tmp
MYSQL_BINLOG=/dev/mapper/volumes/cts_master_mysql80/binlog

#volume
DATA_VOLUME=cts_master_mysql80_data
EXTERNAL_VOLUME=true
