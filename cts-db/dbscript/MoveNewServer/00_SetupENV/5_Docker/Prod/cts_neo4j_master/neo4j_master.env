NEO4J_ACCEPT_LICENSE_AGREEMENT=yes
NEO4J_dbms_active__database=ctsdatacenter

NEO4J_dbms_memory_pagecache_size=9G
NEO4J_dbms_memory_heap_initial__size=7G
NEO4J_dbms_memory_heap_max__size=7G
NEO4J_dbms_security_procedures_unrestricted=algo_*,apoc_*
NEO4J_dbms_windows_service_name=cts_graphdb
NEO4J_browser_allow_outgoing_connections=false
NEO4J_apoc_import_file_enabled=true
NEO4J_apoc_export_file_enabled=true
NEO4J_browser_retain_connection_credentials=false
NEO4J_dbms_logs_query_enabled=true
NEO4J_dbms_logs_query_threshold=120s
NEO4J_dbms_db_timezone=SYSTEM